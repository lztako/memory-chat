generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  name           String?
  conversations  Conversation[]
  memories       Memory[]
  files          UserFile[]
  tasks          Task[]
  skills         UserSkill[]
  tendataUsage   TendataUsage[]
  tokenUsage     TokenUsage[]
  tradeData      UserTradeData[]
  dashboard      UserDashboard?
  agents         UserAgent[]
  docs           UserDoc[]
  createdAt      DateTime        @default(now())
}

model UserDashboard {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  widgets   Json     @default("[]")
  updatedAt DateTime @updatedAt
}

model UserSkill {
  id          String                      @id @default(cuid())
  userId      String
  user        User                        @relation(fields: [userId], references: [id])
  name        String
  trigger     String
  solution    String
  tools       String[]                    @default([])
  usageCount  Int                         @default(0)
  embedding   Unsupported("vector(512)")?
  createdAt   DateTime                    @default(now())
  updatedAt   DateTime                    @updatedAt

  @@index([userId])
}

model UserFile {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  fileName    String
  fileType    String   @default("other")
  description String?
  mimeType    String
  size        Int
  rowCount    Int      @default(0)
  columns     String[]
  data        Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  @@index([userId])
  @@index([userId, fileType])
}

model Conversation {
  id        String               @id @default(cuid())
  userId    String
  user      User                 @relation(fields: [userId], references: [id])
  title     String?
  messages  Message[]
  context   ConversationContext?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  role           String
  content        String
  createdAt      DateTime     @default(now())
}

model Memory {
  id         String                  @id @default(cuid())
  userId     String
  user       User                    @relation(fields: [userId], references: [id])
  type       String
  content    String
  importance Int                     @default(3)
  layer      String                  @default("long_term")
  embedding  Unsupported("vector(512)")?
  lastUsedAt DateTime                @default(now())
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt

  @@index([userId, importance])
  @@index([userId, layer, importance])
}

model Task {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  title         String
  description   String?
  status        String    @default("pending")
  priority      String    @default("normal")
  dueDate       DateTime?
  linkedCompany String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId, status])
  @@index([userId, dueDate])
}

model UserTradeData {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skuTag         String   // HS code หรือ product keyword
  dataType       String   // "company_list" | "company_ranking" | "shipment_records"
  tradeDirection String   // "import" | "export"
  country        String?  // optional country filter applied during fetch
  content        Json     // transformed data from Tendata
  sourceParams   Json?    // original query params (for re-fetch)
  fetchedAt      DateTime @default(now())

  @@index([userId, skuTag])
  @@index([userId, dataType])
}

model TendataUsage {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  date   String // YYYY-MM-DD UTC
  points Int    @default(0)

  @@unique([userId, date])
  @@index([userId])
}

model TokenUsage {
  id           String @id @default(cuid())
  userId       String
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  date         String // YYYY-MM-DD UTC
  inputTokens  Int    @default(0)
  outputTokens Int    @default(0)

  @@unique([userId, date])
  @@index([userId])
}

model UserAgent {
  id           String   @id @default(cuid())
  userId       String?  // null = global agent (ทุก user ใช้ได้)
  user         User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  description  String
  systemPrompt String   @db.Text
  tools        String[]
  model        String   @default("claude-haiku-4-5-20251001")
  maxTurns     Int      @default(5)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@unique([userId, name]) // ป้องกัน duplicate name ต่อ user (null userId = global)
}

model UserDoc {
  id         String                      @id @default(cuid())
  userId     String
  user       User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentId   String?                     // FK → UserSkill.id หรือ UserAgent.id (null สำหรับ resource)
  parentType String                      // "skill" | "agent" | "resource"
  docType    String                      // "reference" | "example" | "workflow" | "overview" | "contact" | "product"
  title      String
  content    String                      @db.Text
  embedding  Unsupported("vector(512)")?
  createdAt  DateTime                    @default(now())
  updatedAt  DateTime                    @updatedAt

  @@index([userId])
  @@index([userId, parentType])
  @@index([userId, parentId])
}

model GlobalInfo {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GlobalDoc {
  id        String   @id @default(cuid())
  category  String   // "company" | "knowledge"
  docType   String   // "overview" | "history" | "service" | "reference" | "workflow"
  title     String
  content   String   @db.Text
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

model ConversationContext {
  id             String       @id @default(cuid())
  conversationId String       @unique
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  currentTask    String?
  quizState      Json?
  pendingItems   String[]     @default([])
  updatedAt      DateTime     @updatedAt
}
